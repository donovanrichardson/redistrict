# Path to the docker-compose file that provides the database service.
# Default uses the bundled postgres defined in docker-compose.db.yml.
# To use an existing postgres container (e.g. a local hex-maps instance), point this
# at that project's docker-compose.yml instead:
#   DB_COMPOSE_PATH=../hex-maps/docker-compose.yml
DB_COMPOSE_PATH=./docker-compose.db.yml

# Postgres connection (used by the app and by docker-compose.db.yml)
POSTGRES_HOST=localhost
POSTGRES_HOST_PORT=5432
POSTGRES_DB=redistrict
POSTGRES_USER=redistrict
POSTGRES_PASSWORD=redistrict
